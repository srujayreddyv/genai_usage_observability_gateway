# Copy to .env for local development. Never commit populated environment files.
APP_ENVIRONMENT=development
ANALYTICS_PROVIDER=mock
PSEUDONYMIZATION_KEY=replace-with-a-local-development-secret
ANTHROPIC_ANALYTICS_API_KEY=
ANTHROPIC_RESULT_LIMIT=100
ANTHROPIC_REQUEST_TIMEOUT_SECONDS=10
# Empty uses the environment-aware default: enabled only in development.
PREVIEW_ENABLED=
PREVIEW_OUTPUT_PATH=telemetry-output/usage-preview.json
# Optional OTLP/HTTP base URL. Development uses console telemetry when unset.
OTEL_EXPORTER_OTLP_ENDPOINT=
# Optional comma-separated, percent-encoded key=value pairs. Treat as secret.
OTEL_EXPORTER_OTLP_HEADERS=
